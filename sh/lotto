printf "\nв”Ӯ      https://www.dhlottery.co.kr\tв”Ӯ \nв”Ӯ\t\t\t\t\tв”Ӯ \n"
printf "в”Ӯ             м ң $(($(($(date +%s)-$(date -d '2002-11-23 20:00' +%s)))/60/60/24/7)) нҡҢ\t\tв”Ӯ \n"
