 case $(expr $ii % 5) in
  1) alpha=A ;;
  2) alpha=B ;;
  3) alpha=C ;;
  4) alpha=D ;;
  0) alpha=E ;;
 esac
 printf "в”Ӯ  $alpha мһҗ  лҸҷ   "
 printf "%02d  " $(shuf -i1-45 -n6 | sort -n)
 printf "\tв”Ӯ \n"
 [ $alpha = E ] && printf "в”Ӯ  ---------------------------------\tв”Ӯ \n"
done

[ $alpha != E ] && printf "в”Ӯ ---------------------------------\tв”Ӯ \n"
p=$((45*44*43*42*41*40/6/5/4/3/2/1))
pp=$(echo "scale=6;100*$ii/$p" | bc | sed 's/^./0./')
/usr/bin/printf "в”Ӯ    кёҲ  м•Ў              пҝҰ%'d\t\tв”Ӯ " $(($ii*1000))
printf "\nв”Ӯ\t\t\t\t\tв”Ӯ \nв”Ӯ  вҖў нҷ•лҘ (P)=$ii/$p=$pp%%\tв”Ӯ \n"
